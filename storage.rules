rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    function signedIn() {
      return request.auth != null;
    }

    function isChatMember(chatId) {
      return signedIn()
        && request.auth.uid in firestore.get(
          /databases/(default)/documents/chats/$(chatId)
        ).data.participantIds;
    }

    match /attachments/{chatId}/{kind}/{messageId}/{fileName=**} {
      allow read: if isChatMember(chatId);
      allow write: if isChatMember(chatId)
        && request.resource != null
        && request.resource.size < 25 * 1024 * 1024;
    }

    match /voice-notes/{chatId}/{fileName} {
      allow read: if isChatMember(chatId);
      allow write: if isChatMember(chatId)
        && request.resource != null
        && request.resource.size < 10 * 1024 * 1024;
    }
  }
}
